
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an application user with access to the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "The unique username used for login."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "roleId": {
          "type": "string",
          "description": "Reference to the Role entity."
        }
      },
      "required": [
        "id",
        "username",
        "roleId"
      ]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Defines user roles.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Role entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the role."
        },
        "description": {
          "type": "string",
          "description": "Explanation of privileges."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "Technician": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Technician",
      "type": "object",
      "description": "Represents technical staff staff.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Technician entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the technician."
        },
        "phoneTariff": {
          "type": "string",
          "description": "Work phone."
        },
        "phonePersonal": {
          "type": "string",
          "description": "Personal phone."
        },
        "workRegime": {
          "type": "string",
          "description": "Work schedule type.",
          "enum": ["Comercial", "12x36"]
        },
        "isOnDuty": {
          "type": "boolean",
          "description": "Currently on call."
        }
      },
      "required": [
        "id",
        "name",
        "workRegime"
      ]
    },
    "ScheduledBlock": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ScheduledBlock",
      "type": "object",
      "description": "Represents a time block for a technician.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (usually time)."
        },
        "technicianId": {
          "type": "string",
          "description": "Reference to technician."
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "format": "date-time"
        },
        "equipe1": {
          "type": "boolean"
        },
        "equipe2": {
          "type": "boolean"
        },
        "markedByUserId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "technicianId",
        "startTime",
        "endTime"
      ]
    },
    "DutyCity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DutyCity",
      "type": "object",
      "description": "Represents a city where technicians are currently on duty.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "City name."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether duty is currently active in this city."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "isActive"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/roles/{roleId}",
        "definition": {
          "entityName": "Role",
          "schema": {
            "$ref": "#/backend/entities/Role"
          },
          "description": "Stores role definitions."
        }
      },
      {
        "path": "/technicians/{technicianId}",
        "definition": {
          "entityName": "Technician",
          "schema": {
            "$ref": "#/backend/entities/Technician"
          },
          "description": "Stores technician profiles."
        }
      },
      {
        "path": "/technicians/{technicianId}/scheduledBlocks/{scheduledBlockId}",
        "definition": {
          "entityName": "ScheduledBlock",
          "schema": {
            "$ref": "#/backend/entities/ScheduledBlock"
          },
          "description": "Stores specific time blocks."
        }
      },
      {
        "path": "/roles_tac_members/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Identifies TAC Members."
        }
      },
      {
        "path": "/dutyCities/{cityId}",
        "definition": {
          "entityName": "DutyCity",
          "schema": {
            "$ref": "#/backend/entities/DutyCity"
          },
          "description": "Stores cities with active duty."
        }
      }
    ]
  }
}
