
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTacMember() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_tac_members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    match /roles/{roleId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /technicians/{technicianId} {
      allow get, list: if true;
      allow create, update, delete: if isTacMember();

      match /scheduledBlocks/{scheduledBlockId} {
        allow get, list: if true;
        allow create: if isTacMember() && request.resource.data.markedByUserId == request.auth.uid;
        allow update, delete: if isTacMember();
      }
    }

    match /dutyCities/{cityId} {
      allow get, list: if true;
      allow create, update, delete: if isTacMember();
    }

    match /roles_tac_members/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if false;
    }
  }
}
