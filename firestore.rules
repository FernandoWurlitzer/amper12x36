/**
 * Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a role-based access control system specifically designed for a 
 * technician scheduling application. It prioritizes "Authorization Independence" by using 
 * a dedicated lookup collection (`roles_tac_members`) to identify privileged users 
 * (TAC Members) who have the authority to manage technician schedules.
 * 
 * Data Structure:
 * - /users/{userId}: Private user profiles.
 * - /roles/{roleId}: Publicly readable reference data for system roles.
 * - /technicians/{technicianId}: Publicly readable technician profiles.
 * - /technicians/{technicianId}/scheduledBlocks/{blockId}: Publicly readable availability 
 *   blocks, with write access restricted to TAC Members.
 * - /roles_tac_members/{userId}: A restricted lookup collection for DBAC (Database-Based Access Control).
 * 
 * Key Security Decisions:
 * 1. Denormalization for Authorization: To ensure performant and atomic security checks, 
 *    the status of a "TAC Member" is mirrored in a flat top-level collection. This allows 
 *    the rules to use `exists()` calls rather than complex joins.
 * 2. Public Visibility: Technician schedules are readable by ANYONE (even unauthenticated) 
 *    to facilitate viewing availability, but modification is strictly gated.
 * 3. Relational Integrity: On creation of schedule blocks, the rules enforce that the 
 *    `markedByUserId` matches the authenticated user's ID for auditing purposes.
 * 4. Structural Segregation: Administrative role mapping is kept separate from standard 
 *    user profiles to prevent accidental privilege escalation.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a TAC Member using the DBAC lookup collection. */
    function isTacMember() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_tac_members/$(request.auth.uid));
    }

    /** @description Combines ownership check with document existence for write operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual user profiles. Users can only manage their own data.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for role definitions. Readable by anyone.
     */
    match /roles/{roleId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for technician profiles. Publicly readable, manageable by TAC Members.
     */
    match /technicians/{technicianId} {
      allow get, list: if true;
      allow create, update, delete: if isTacMember();

      /**
       * @description Rules for specific time blocks. Readable by anyone, managed by TAC Members.
       */
      match /scheduledBlocks/{scheduledBlockId} {
        allow get, list: if true;
        allow create: if isTacMember() && request.resource.data.markedByUserId == request.auth.uid;
        allow update, delete: if isTacMember() && resource != null;
      }
    }

    /**
     * @description Rules for the TAC Member lookup collection used for DBAC.
     */
    match /roles_tac_members/{userId} {
      allow get: if isOwner(userId) || isTacMember();
      allow list: if false;
      allow create, update, delete: if false;
    }
  }
}